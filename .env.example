# ── Server ───────────────────────────────────────────────────────────────────
NODE_ENV=production

# Port the Node.js server listens on
PORT=3000

# Public URL of the app — required by SvelteKit for CSRF protection
ORIGIN=https://yourdomain.com

# Max upload size in bytes (default 512 kb — raise for image uploads)
BODY_SIZE_LIMIT=20971520

# ── App secrets — CHANGE BOTH BEFORE DEPLOYING ───────────────────────────────

# Password shown on the login screen
VITA_PASSWORD=vita2303

# Secret stored in the session cookie — use a long random string
# Generate one: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
VITA_SECRET=change-this-to-a-long-random-string

# ── Storage paths (optional, defaults to ./uploads and ./data) ────────────────
# UPLOADS_DIR=/var/vita/uploads
# DATA_DIR=/var/vita/data

# ── Text-to-speech (ElevenLabs) ──────────────────────────────────────────────
# Optional. If ELEVENLABS_API_KEY is unset, the app falls back to the browser's
# built-in voice automatically — no error, just lower quality.

# Your ElevenLabs API key (Profile → API Keys). Keep this secret — server only.
ELEVENLABS_API_KEY=

# Voice to use. Defaults to "Rachel" (21m00Tcm4TlvDq8ikWAM), a stock voice on
# every account. Copy any voice ID from the ElevenLabs "Voices" page to change it.
# ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# Model. Multilingual is required for correct Latin pronunciation.
# ELEVENLABS_MODEL_ID=eleven_multilingual_v2
